# Опційно: operateAs — лише якщо токен має право impersonation (рідко)
WIALON_OPERATE_AS=

# Довідково: логін головного акаунта (НЕ використовується в API автоматично)
WIALON_USER=
WIALON_PASSWORD=

WIALON_REPORT_RESOURCE_ID=2217
WIALON_FUEL_REPORT_TEMPLATE_ID=5
WIALON_TRIPS_REPORT_TEMPLATE_ID=11
WIALON_GEOFENCES_REPORT_TEMPLATE_ID=1
